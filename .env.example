# Örnek .env dosyası - GÜVENLİK: Gerçek secret'ları buraya yazmayın, bu dosyayı .gitignore'a ekleyin
# API Football
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY_HERE
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/analiz_db

# Redis
REDIS_URL=redis://redis:6379/0

# Google OAuth (NextAuth/Next.js frontend için)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# App settings
SECRET_KEY=change-this-to-a-secure-random-value
